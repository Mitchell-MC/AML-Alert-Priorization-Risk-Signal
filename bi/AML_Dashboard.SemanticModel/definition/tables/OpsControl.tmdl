table OpsControl

	column pipeline_name
		dataType: string
		summarizeBy: none
		sourceColumn: pipeline_name

	column batch_id
		dataType: string
		summarizeBy: none
		sourceColumn: batch_id

	column processed_row_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: processed_row_count

	column dead_letter_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: dead_letter_count

	column lag_seconds
		dataType: double
		formatString: 0.0
		summarizeBy: average
		sourceColumn: lag_seconds

	column freshness_status
		dataType: string
		summarizeBy: none
		sourceColumn: freshness_status

	column recorded_at
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: recorded_at

	partition OpsControl = m
		mode: import
		source =
				let
				    Source = Databricks.Catalogs("dbc-08add949-9c19.cloud.databricks.com", "/sql/1.0/warehouses/59901b31d31db40a", [Catalog=null, Database=null]),
				    aml_dev_Database = Source{[Name="aml_dev",Kind="Database"]}[Data],
				    gold_Schema = aml_dev_Database{[Name="gold",Kind="Schema"]}[Data],
				    ops_control_Table = gold_Schema{[Name="ops_control",Kind="Table"]}[Data]
				in
				    ops_control_Table

	annotation PBI_ResultType = Table
