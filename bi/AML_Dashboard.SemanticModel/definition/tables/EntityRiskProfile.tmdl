	/// Watchlist match confidence expressed as text, derived from best_band_rank -- kept as a
	/// calculated column (not a stored Gold column) so the mapping lives in one visible place.
	column watchlist_confidence_label = ```
			SWITCH(
			    TRUE(),
			    EntityRiskProfile[best_band_rank] = 3, "Exact",
			    EntityRiskProfile[best_band_rank] = 2, "Strong",
			    EntityRiskProfile[best_band_rank] = 1, "Weak",
			    "None"
			)
			```
		formatString: 0
		lineageTag = e1a1b001-0001-4a11-9a11-000000000020
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition EntityRiskProfile = m
