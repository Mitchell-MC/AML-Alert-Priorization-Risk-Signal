table WatchlistMatchSummary

	column watchlist_entity_id
		dataType: string
		summarizeBy: none
		sourceColumn: watchlist_entity_id

	column matched_account_count
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: matched_account_count

	column highest_confidence_band
		dataType: string
		summarizeBy: none
		sourceColumn: highest_confidence_band

	column risk_type
		dataType: string
		summarizeBy: none
		sourceColumn: risk_type

	partition WatchlistMatchSummary = m
		mode: import
		source =
				// NOTE: gold.watchlist_match_summary.jurisdictions is ARRAY<STRING> in Delta.
				// This query intentionally omits it -- Power Query surfaces array columns as
				// `list` values, not text, and needs a one-time "Extract Values" or
				// "Expand to New Rows" step done in the Power Query Editor UI rather than
				// guessed at blind here. Add it back via: Home > Transform Data > select the
				// jurisdictions column > Transform > Extract Values (comma-delimited), or List
				// Tools > To Table if you want one row per (entity, jurisdiction) instead.
				let
				    Source = Databricks.Catalogs("dbc-08add949-9c19.cloud.databricks.com", "/sql/1.0/warehouses/59901b31d31db40a", [Catalog=null, Database=null]),
				    aml_dev_Database = Source{[Name="aml_dev",Kind="Database"]}[Data],
				    gold_Schema = aml_dev_Database{[Name="gold",Kind="Schema"]}[Data],
				    watchlist_match_summary_Table = gold_Schema{[Name="watchlist_match_summary",Kind="Table"]}[Data],
				    RemovedJurisdictions = Table.RemoveColumns(watchlist_match_summary_Table, {"jurisdictions"})
				in
				    RemovedJurisdictions

	annotation PBI_ResultType = Table
